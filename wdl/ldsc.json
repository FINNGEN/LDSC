{
    "ldsc_rg.docker": "eu.gcr.io/finngen-sandbox-v3-containers/ldsc:rsid_munge",
    "ldsc_rg.only_het": True,
    "ldsc_rg.meta_fg": "gs://r14-data/genetic_correlation/inputs/r14_test.ldsc_table.txt",
    #optional second list (if absent the first will be used instead )
    #"ldsc_rg.comparison_fg": "gs://r7_data/ldsc/test_data_2.txt",
    # output prefix
    "ldsc_rg.name": "finngen_R14",
    # choose LD score population
    "ldsc_rg.population" : "FIN",
    "ldsc_rg.ld_path":{"EUR":"gs://finngen-production-library-green/ldsc/eur_ld.txt","FIN":"gs://finngen-production-library-green/ldsc/fin_ld.txt"},

    #FILTER CHUNKS
    "ldsc_rg.filter_meta.filter_chunks": 100,

    #PREMUNGE
    "ldsc_rg.premunge_ss.p_col": "pval",
    "ldsc_rg.premunge_ss.rsid_col": "rsids",
    "ldsc_rg.premunge_ss.a1_effect_col": "alt",
    "ldsc_rg.premunge_ss.a2_ne_col": "ref",
    "ldsc_rg.premunge_ss.beta_col": "beta",
    #"ldsc_rg.premunge_ss.chrom_col": "String? (optional)", # not needed because rsid present
    #"ldsc_rg.premunge_ss.pos_col": "String? (optional)",

    #MUNGE
    "ldsc_rg.munge_ldsc.snplist": "gs://finngen-production-library-green/ldsc/w_hm3.snplist",
    "ldsc_rg.return_couples.chunks": 400,
    
    #multi inputs:
    "ldsc_rg.multi_rg.cpus": 32,
    # optional inputs for ldsc
    #"ldsc_rg.multi_rg.args" : ""

    #DOCKERS
    #"ldsc_rg.munge_ldsc.munge_docker": "eu.gcr.io/finngen-sandbox-v3-containers/ldsc:rsid_munge",
